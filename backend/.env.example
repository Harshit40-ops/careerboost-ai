# ─────────────────────────────────────────────────────────────
# Copy this file to ".env" and fill in your real values.
# NEVER commit the real .env or expose these keys to the frontend.
# ─────────────────────────────────────────────────────────────

# Secret used to sign JWT tokens. Generate a strong one, e.g.:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-long-random-string

# How long an access token stays valid (minutes).
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ── LLM provider ──────────────────────────────────────────────
# Which provider to use for scoring & interview questions:
#   "anthropic"  -> uses ANTHROPIC_API_KEY  (Claude)
#   "openai"     -> uses OPENAI_API_KEY (+ optional OPENAI_BASE_URL for
#                   any OpenAI-COMPATIBLE provider: Groq, Gemini, OpenRouter)
#   "mock"       -> no API key needed; built-in heuristic, runs 100% free.
LLM_PROVIDER=mock

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- OpenAI-compatible settings ---
# Works with real OpenAI OR any free OpenAI-compatible provider below.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=

# ──────────────────────────────────────────────────────────────
# FREE real-LLM presets (no credit card). Pick ONE, set LLM_PROVIDER=openai,
# paste your key into OPENAI_API_KEY, and copy its MODEL + BASE_URL above.
#
# 1) Groq (recommended — fast & free): https://console.groq.com/keys
#    OPENAI_MODEL=llama-3.3-70b-versatile
#    OPENAI_BASE_URL=https://api.groq.com/openai/v1
#
# 2) Google Gemini (free tier): https://aistudio.google.com/app/apikey
#    OPENAI_MODEL=gemini-2.0-flash
#    OPENAI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/
#
# 3) OpenRouter (free models): https://openrouter.ai/keys
#    OPENAI_MODEL=meta-llama/llama-3.3-70b-instruct:free
#    OPENAI_BASE_URL=https://openrouter.ai/api/v1
# ──────────────────────────────────────────────────────────────

# Comma-separated list of frontend origins allowed by CORS.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
